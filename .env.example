# Copy this file to `.env` and fill in your values. `.env` is gitignored — never commit it.
# Load it into your shell before running:  set -a && source .env && set +a

ANTHROPIC_API_KEY=sk-ant-your-key-here

PGAGENT_DB_URL=jdbc:postgresql://localhost:5432/pgagent_demo
PGAGENT_DB_USER=pgagent
PGAGENT_DB_PASSWORD=pgagent

# Email report — sent after each agent run.
# For Gmail, use an App Password (https://myaccount.google.com/apppasswords).
MAIL_USERNAME=you@gmail.com
MAIL_PASSWORD=your-app-password
REPORT_RECIPIENT_EMAIL=recipient@example.com
